# Copy this file to .env.local and fill in real values.
# .env.local is gitignored. In CI (GitHub Actions), set these as secrets
# instead of committing them.

# GA4 — manual CSV ingest. Export the three free-form reports from GA4 and
# drop the CSVs into the data/ folder. The pull script picks the most recent
# ones by filename (which conventionally start with YYYY-MM-DD).
#
# Expected filename patterns (prefix is free-form):
#   *engaged_sessions_by_date*.csv
#   *signup_events_by_channel*.csv
#   *all_engaged_sessions_by_channel*.csv
#
# Date range for the GA4 reports: start from the MONDAY of the week containing
# (today - 30 days), end on today. This ensures the leftmost bar of the weekly
# charts has a full Mon-Sun's worth of data even when the 30-day cutoff lands
# mid-week. Example: if today is May 15, "today - 30 days" = Apr 15 (Wed),
# Monday of that week = Apr 13, so export range = Apr 13 → May 15.
# The Amplitude + HubSpot fetchers do this automatically; GA4 is manual so
# you need to set the date range in the GA4 UI yourself.
#
# Channel-group dimension: in GA4, use "Session Mutiny - With AI Referrals"
# (custom channel group), NOT "Session default channel group". The custom
# group adds an "AI Referrals" bucket for chatgpt/claude/perplexity/gemini
# traffic. (The pull script's header sniffer accepts either header for
# backward compat, but new exports should use the Mutiny custom group.)
#
# Override the directory if needed:
# GA4_CSV_DIR=data

# HubSpot Private App access token. Create at:
#   HubSpot → Settings → Integrations → Private Apps
# Required scopes: crm.objects.contacts.read, crm.schemas.contacts.read
# (For the HubSpot logos PROXY — PULL_LOGOS=1 — also add
#  crm.objects.companies.read + crm.objects.deals.read.)
HUBSPOT_PRIVATE_APP_TOKEN=

# ── Cumulative active logos: where the series comes from ──────────────────
# Preference order in pull-data.mjs: revenue-repo → HubSpot proxy → baked/prior.
#
# BEST (single source of truth): read the already-computed series from the
# private revenue dashboard repo so this dashboard shows the EXACT same
# "Total active logos" the revenue dashboard does. Set LOGOS_SOURCE and a
# fine-grained PAT with read-only Contents on the revenue repo.
# LOGOS_SOURCE=revenue-repo
# REVENUE_REPO_TOKEN=
# REVENUE_REPO=UncleAchoo/revenue-dashboard-official
# REVENUE_LOGOS_PATH=stripe_data.json
# REVENUE_REPO_REF=main
# Local testing without a token: point this at a downloaded stripe_data.json
# (with LOGOS_SOURCE=revenue-repo) to exercise the ingestion offline.
# REVENUE_LOGOS_FIXTURE=/path/to/stripe_data.json
#
# FALLBACK (HubSpot proxy): recompute logos here from HubSpot (List 5010
# enterprise + PLG proxy). Equals the canonical count today but can drift.
# PULL_LOGOS=1
# STRIPE_HISTORY_START=2026-03-26

# Amplitude Dashboard REST API credentials. Find at:
#   Amplitude → Settings → Organization → Projects → Mutiny Production → General
AMPLITUDE_API_KEY=
AMPLITUDE_SECRET=

# Peec AI API key (AEO visibility data). Find at:
#   Peec → settings → API / Developer keys
# Project ID + Mutiny brand ID default to Mutiny's values; override only if
# you're pointing the script at a different Peec project.
PEEC_API_KEY=
# PEEC_API_BASE=https://app.peec.ai/api/v1
# PEEC_PROJECT_ID=or_0887d1ed-129a-4dcd-a14c-d5fd9905d06c
# PEEC_MUTINY_BRAND_ID=kw_7af93fc0-d981-4f63-86d5-0fc3348809b3
# PEEC_WINDOW_START=2026-04-23

# Optional window override. Defaults to start=2026-04-27, end=today.
# WINDOW_START=2026-04-27
# WINDOW_END=2026-05-13
