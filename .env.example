# Copy this file to .env.local and fill in real values.
# .env.local is gitignored. In CI (GitHub Actions), set these as secrets
# instead of committing them.

# GA4 — manual CSV ingest. Export the three free-form reports from GA4 and
# drop the CSVs into the data/ folder. The pull script picks the most recent
# ones by filename (which conventionally start with YYYY-MM-DD).
#
# Expected filename patterns (prefix is free-form):
#   *engaged_sessions_by_date*.csv
#   *signup_events_by_channel*.csv
#   *all_engaged_sessions_by_channel*.csv
#
# Channel-group dimension: in GA4, use "Session Mutiny - With AI Referrals"
# (custom channel group), NOT "Session default channel group". The custom
# group adds an "AI Referrals" bucket for chatgpt/claude/perplexity/gemini
# traffic. (The pull script's header sniffer accepts either header for
# backward compat, but new exports should use the Mutiny custom group.)
#
# Override the directory if needed:
# GA4_CSV_DIR=data

# HubSpot Private App access token. Create at:
#   HubSpot → Settings → Integrations → Private Apps
# Required scopes: crm.objects.contacts.read, crm.schemas.contacts.read
HUBSPOT_PRIVATE_APP_TOKEN=

# Amplitude Dashboard REST API credentials. Find at:
#   Amplitude → Settings → Organization → Projects → Mutiny Production → General
AMPLITUDE_API_KEY=
AMPLITUDE_SECRET=

# Peec AI API key (AEO visibility data). Find at:
#   Peec → settings → API / Developer keys
# Project ID + Mutiny brand ID default to Mutiny's values; override only if
# you're pointing the script at a different Peec project.
PEEC_API_KEY=
# PEEC_API_BASE=https://app.peec.ai/api/v1
# PEEC_PROJECT_ID=or_0887d1ed-129a-4dcd-a14c-d5fd9905d06c
# PEEC_MUTINY_BRAND_ID=kw_7af93fc0-d981-4f63-86d5-0fc3348809b3
# PEEC_WINDOW_START=2026-04-23

# Optional window override. Defaults to start=2026-04-27, end=today.
# WINDOW_START=2026-04-27
# WINDOW_END=2026-05-13
